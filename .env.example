# ============================================================
# ResumeFlow — Environment Variables (EXAMPLE)
# ============================================================
# Copy this file to .env.local and fill in your actual keys:
#   cp .env.example .env.local
# ============================================================

NEXT_PUBLIC_CONVEX_URL=https://your-project-123.convex.cloud
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
CLERK_JWT_ISSUER_DOMAIN=https://your-instance.clerk.accounts.dev
# LAN dev: your IP:port + add http://IP:3000 in Clerk → Allowed origins
NEXT_DEV_ALLOWED_ORIGINS=192.168.1.100:3000
NVIDIA_NIM_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Upstash Redis (Next.js compile locks + optional Convex JD analysis cache)
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# Sentry Error Monitoring & Observability
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxx.ingest.sentry.io/xxxxxxx
SENTRY_DSN=https://xxxxxxxx.ingest.sentry.io/xxxxxxx
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxx

